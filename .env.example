# ----------------------------------------
# 공개 환경변수 (브라우저에 노출됨)
# ----------------------------------------

# canonical URL, OG, sitemap 기준 도메인
NEXT_PUBLIC_SITE_URL=https://example.com

# 헤더·푸터 표시 이름 (선택)
NEXT_PUBLIC_APP_NAME=

# Twitter metadata creator (선택)
NEXT_PUBLIC_TWITTER_HANDLE=

# ----------------------------------------
# 서버 전용 환경변수 (브라우저에 노출 안 됨)
# ----------------------------------------

# Notion API 키
NOTION_API_KEY=

# Notion 데이터베이스 ID
NOTION_DATABASE_ID=
